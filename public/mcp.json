{
    "name": "hire_a_human",
    "description": "Find and hire verified tech professionals with AI-assisted screening and structured profiles.",
    "input_schema": {
        "type": "object",
        "properties": {
            "skills": {
                "type": "string",
                "description": "Comma separated skills to search for (e.g. React, Python)"
            },
            "min_experience": {
                "type": "integer",
                "description": "Minimum years of experience"
            },
            "location": {
                "type": "string",
                "description": "Preferred location or 'Remote'"
            }
        },
        "required": [
            "skills"
        ]
    }
}