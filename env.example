# InsForge Configuration
# Get these values from your InsForge dashboard: https://insforge.dev

# Your InsForge backend URL (required for authentication)
VITE_INSFORGE_URL=https://your-app.region.insforge.app
VITE_INSFORGE_BASE_URL=https://your-app.region.insforge.app

# Anonymous key (optional, only needed for database/storage operations)
VITE_INSFORGE_ANON_KEY=your_insforge_anon_key_here

# Tambo AI Configuration
# Get your API key from: https://console.tambo.co
VITE_TAMBO_API_KEY=your_tambo_api_key_here
